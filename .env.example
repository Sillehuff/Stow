# Frontend (Vite) environment. Copy to .env.local for development.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Region for Firebase callables. Must match FUNCTIONS_REGION set on the
# functions runtime (see functions/.env.example).
VITE_FUNCTIONS_REGION=us-central1

# Set to "true" when running `firebase emulators:start` locally so the client
# connects to the Auth/Firestore/Functions/Storage emulators instead of
# production services.
VITE_USE_FIREBASE_EMULATORS=false

# NOTE: Functions runtime environment variables (KMS_KEY_NAME, APP_BASE_URL,
# LOCAL_SECRET_ENCRYPTION_KEY, FUNCTIONS_REGION) are documented separately in
# functions/.env.example.
