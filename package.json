{
  "name": "stow-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --exclude 'tests/firestore.rules.test.ts' --exclude 'tests/smoke/**'",
    "test:rules": "./scripts/with-java.sh firebase emulators:exec --project demo-stow --only firestore \"vitest run tests/firestore.rules.test.ts\"",
    "test:smoke": "./scripts/with-java.sh firebase emulators:exec --project demo-stow --only auth,firestore,storage \"playwright test --grep-invert @live-gemini\"",
    "test:smoke:live-gemini": "./scripts/with-java.sh firebase emulators:exec --project demo-stow --only auth,firestore,storage,functions \"playwright test tests/smoke/live-gemini.spec.ts\"",
    "functions:build": "npm --prefix functions run build",
    "functions:test": "npm --prefix functions run test",
    "functions:serve": "npm --prefix functions run serve",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "firebase": "^11.4.0",
    "lucide-react": "^0.511.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.58.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "firebase-admin": "^12.7.0",
    "firebase-tools": "^15.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.7"
  }
}
