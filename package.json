{
  "name": "stow-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run test:app",
    "test:app": "vitest run src",
    "test:rules": "vitest run --config vitest.rules.config.ts tests/rules",
    "test:emulator-smoke": "tsx scripts/emulator-smoke.ts",
    "test:functions": "npm --prefix functions run test",
    "verify": "npm run verify:local && npm run verify:emulator",
    "verify:local": "npm run typecheck && npm run test:app && npm run test:functions && npm run functions:build && npm run build",
    "verify:emulator": "node ./scripts/verify-emulator.mjs",
    "verify:inside-emulator": "npm run test:rules && npm run seed:qa && npm run test:emulator-smoke",
    "functions:build": "npm --prefix functions run build",
    "functions:serve": "npm --prefix functions run serve",
    "emulators:start": "firebase emulators:start --project stow-50f36 --only auth,firestore,functions,storage",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:qa": "tsx scripts/seed-qa.ts",
    "e2e:open": "bash ./scripts/playwright-session.sh open",
    "e2e:snapshot": "bash ./scripts/playwright-session.sh snapshot",
    "e2e:screenshot": "bash ./scripts/playwright-session.sh screenshot",
    "e2e:console": "bash ./scripts/playwright-session.sh console",
    "e2e:close": "bash ./scripts/playwright-session.sh close"
  },
  "dependencies": {
    "firebase": "^11.4.0",
    "lucide-react": "^0.511.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "firebase-admin": "^12.7.0",
    "firebase-tools": "^15.15.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.7"
  }
}
