rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function membershipDoc(householdId) {
      return /databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid);
    }

    function householdDoc(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() && exists(membershipDoc(householdId));
    }

    function memberRole(householdId) {
      return get(membershipDoc(householdId)).data.role;
    }

    function isHouseholdAdmin(householdId) {
      return isHouseholdMember(householdId) && (memberRole(householdId) in ['OWNER', 'ADMIN']);
    }

    function isHouseholdBeingCreatedBySelf(householdId) {
      return isSignedIn()
        && !exists(householdDoc(householdId))
        && existsAfter(householdDoc(householdId))
        && getAfter(householdDoc(householdId)).data.createdBy == request.auth.uid;
    }

    function isBootstrapOwnerMemberCreate(householdId, uid) {
      return isHouseholdBeingCreatedBySelf(householdId)
        && uid == request.auth.uid
        && request.resource.data.role == 'OWNER'
        && request.resource.data.createdBy == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /households/{householdId} {
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read: if isHouseholdMember(householdId);
      allow update: if isHouseholdAdmin(householdId);
      allow delete: if false;

      match /members/{uid} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isBootstrapOwnerMemberCreate(householdId, uid);
        allow update, delete: if false;
      }

      match /invites/{inviteId} {
        allow read: if isHouseholdAdmin(householdId);
        allow create, update, delete: if false;
      }

      match /spaces/{spaceId} {
        allow read: if isHouseholdMember(householdId);
        // create permits the bootstrap transaction, where the member doc isn't yet committed.
        allow create: if isHouseholdMember(householdId) || isHouseholdBeingCreatedBySelf(householdId);
        allow update, delete: if isHouseholdMember(householdId);

        match /areas/{areaId} {
          allow read: if isHouseholdMember(householdId);
          allow create: if request.resource.data.householdId == householdId && (isHouseholdMember(householdId) || isHouseholdBeingCreatedBySelf(householdId));
          allow update: if request.resource.data.householdId == householdId && isHouseholdMember(request.resource.data.householdId);
          allow delete: if resource.data.householdId == householdId && isHouseholdMember(resource.data.householdId);
        }
      }

      match /items/{itemId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if isHouseholdMember(householdId);
      }

      match /itemDrafts/{draftId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if isHouseholdMember(householdId);
      }

      match /packingLists/{listId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if isHouseholdMember(householdId);
      }

      match /activity/{activityId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update, delete: if false;
      }

      match /settings/llm {
        allow read: if isHouseholdAdmin(householdId);
        allow create: if isHouseholdAdmin(householdId) || isHouseholdBeingCreatedBySelf(householdId);
        allow update, delete: if isHouseholdAdmin(householdId);
      }

      match /settings/llmSecret {
        allow read, write: if false;
      }

      match /settings/{docId} {
        allow read, write: if false;
      }

      match /visionJobs/{jobId} {
        // Audit records: the backend writes these via the Admin SDK (bypasses rules).
        // Clients may only create their own record; they can never forge createdBy,
        // edit, or delete another member's job history.
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Collection-group queries on `areas` require a recursive wildcard match.
    // READ ONLY: this block exists solely to authorize `collectionGroup("areas")`
    // queries, which are scoped by `where("householdId", "==", ...)` and matched
    // against the *stored* householdId. Writes must NOT be granted here — Firestore
    // unions (ORs) matching rules, so gating a write on the *incoming* payload's
    // householdId would let a member of household B write to household A's area
    // path simply by putting householdId:"B" in the payload, bypassing the
    // path-scoped rule. All legitimate area writes go through the path-scoped
    // rules under /spaces/{spaceId}/areas above.
    match /{path=**}/areas/{areaId} {
      allow read: if isHouseholdMember(resource.data.householdId);
      allow create, update, delete: if false;
    }
  }
}
