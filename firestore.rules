rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function membershipDoc(householdId) {
      return /databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid);
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() && exists(membershipDoc(householdId));
    }

    function memberRole(householdId) {
      return get(membershipDoc(householdId)).data.role;
    }

    function isHouseholdAdmin(householdId) {
      return isHouseholdMember(householdId) && (memberRole(householdId) in ['OWNER', 'ADMIN']);
    }

    function spaceDoc(householdId, spaceId) {
      return /databases/$(database)/documents/households/$(householdId)/spaces/$(spaceId);
    }

    function areaDoc(householdId, spaceId, areaId) {
      return /databases/$(database)/documents/households/$(householdId)/spaces/$(spaceId)/areas/$(areaId);
    }

    function hasNoDeleteLifecycleFields(data) {
      return !('deletedAt' in data)
        && !('deletingAt' in data)
        && !('deletingBy' in data)
        && !('deleteTargetSpaceId' in data)
        && !('deleteTargetAreaId' in data);
    }

    function spaceExistsAndOpen(householdId, spaceId) {
      return exists(spaceDoc(householdId, spaceId))
        && hasNoDeleteLifecycleFields(get(spaceDoc(householdId, spaceId)).data);
    }

    function areaExistsAndOpen(householdId, spaceId, areaId) {
      return exists(areaDoc(householdId, spaceId, areaId))
        && get(areaDoc(householdId, spaceId, areaId)).data.householdId == householdId
        && get(areaDoc(householdId, spaceId, areaId)).data.spaceId == spaceId
        && hasNoDeleteLifecycleFields(get(areaDoc(householdId, spaceId, areaId)).data);
    }

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /households/{householdId} {
      allow create: if false;
      allow read: if isHouseholdMember(householdId);
      allow update: if isHouseholdAdmin(householdId);
      allow delete: if false;

      match /members/{uid} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if false;
      }

      match /invites/{inviteId} {
        allow read: if isHouseholdAdmin(householdId);
        allow create, update, delete: if false;
      }

      match /spaces/{spaceId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId)
          && request.resource.data.householdId == householdId
          && hasNoDeleteLifecycleFields(request.resource.data);
        allow update: if isHouseholdMember(householdId)
          && resource.data.householdId == householdId
          && request.resource.data.householdId == householdId
          && hasNoDeleteLifecycleFields(resource.data)
          && hasNoDeleteLifecycleFields(request.resource.data);
        allow delete: if false;

        match /areas/{areaId} {
          allow read: if isHouseholdMember(householdId);
          allow create: if request.resource.data.householdId == householdId
            && request.resource.data.spaceId == spaceId
            && isHouseholdMember(request.resource.data.householdId)
            && spaceExistsAndOpen(householdId, spaceId)
            && hasNoDeleteLifecycleFields(request.resource.data);
          allow update: if request.resource.data.householdId == householdId
            && request.resource.data.spaceId == spaceId
            && resource.data.householdId == householdId
            && resource.data.spaceId == spaceId
            && isHouseholdMember(request.resource.data.householdId)
            && spaceExistsAndOpen(householdId, spaceId)
            && hasNoDeleteLifecycleFields(resource.data)
            && hasNoDeleteLifecycleFields(request.resource.data);
          allow delete: if false;
        }
      }

      match /items/{itemId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId)
          && request.resource.data.householdId == householdId
          && hasNoDeleteLifecycleFields(request.resource.data)
          && spaceExistsAndOpen(householdId, request.resource.data.spaceId)
          && areaExistsAndOpen(householdId, request.resource.data.spaceId, request.resource.data.areaId);
        allow update: if isHouseholdMember(householdId)
          && resource.data.householdId == householdId
          && request.resource.data.householdId == householdId
          && hasNoDeleteLifecycleFields(resource.data)
          && hasNoDeleteLifecycleFields(request.resource.data)
          && spaceExistsAndOpen(householdId, resource.data.spaceId)
          && areaExistsAndOpen(householdId, resource.data.spaceId, resource.data.areaId)
          && spaceExistsAndOpen(householdId, request.resource.data.spaceId)
          && areaExistsAndOpen(householdId, request.resource.data.spaceId, request.resource.data.areaId);
        allow delete: if false;
      }

      match /packingLists/{listId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if false;
      }

      match /settings/{docId} {
        allow read: if docId != 'llmSecret' && isHouseholdMember(householdId);
        allow write: if docId != 'llmSecret' && isHouseholdAdmin(householdId);
      }

      match /visionJobs/{jobId} {
        allow read: if isHouseholdMember(householdId);
        allow write: if false;
      }
    }
  }
}
