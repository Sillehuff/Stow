rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(householdId) {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    match /households/{householdId}/{allPaths=**} {
      allow read: if isMember(householdId);
      // create/update must be image-only and bounded; delete is split out so it
      // is not blocked by size/contentType checks (request.resource is null on delete).
      // Boundary <= matches vision.ts (> MAX_IMAGE_BYTES), so exactly 10 MB is allowed
      // by both guards. contentType here is the CLIENT-declared metadata, not sniffed
      // content — vision.ts re-reads stored metadata server-side before any model call,
      // so don't treat this rule as proof the bytes are really an image.
      allow create, update: if isMember(householdId)
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isMember(householdId);
    }
  }
}
