# Production secret encryption.
# Prefer KMS_KEY_NAME for deployed functions. This is a resource name, not the
# actual API key being encrypted.
KMS_KEY_NAME=projects/your-project/locations/global/keyRings/stow-secrets/cryptoKeys/llm-secret-encryption

# Local fallback for emulators/dev only. Use a long random value if you need
# deterministic local encrypted secrets.
# LOCAL_SECRET_ENCRYPTION_KEY=
