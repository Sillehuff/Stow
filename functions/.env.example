# Functions runtime environment variables.
# Copy to functions/.env for local development. Set equivalent values in your
# Firebase Functions runtime config (or Secret Manager) for production.

# Region for all callables. Defaults to us-central1 when unset.
FUNCTIONS_REGION=us-central1

# Base URL used when generating household invite links. If unset, the
# invite callable falls back to the request's Origin header.
APP_BASE_URL=http://localhost:5173

# --- LLM secret encryption ---
# Option A (PRODUCTION): point at a Cloud KMS symmetric key. Format:
#   projects/<PROJECT>/locations/<LOC>/keyRings/<RING>/cryptoKeys/<KEY>
# The functions runtime service account must have roles/cloudkms.cryptoKeyEncrypterDecrypter.
# KMS_KEY_NAME=

# Option B (DEV ONLY): seed for the local AES-256-GCM fallback. If
# KMS_KEY_NAME is unset, secrets are encrypted with a key derived from this
# value. The built-in default is insecure — set your own value for any shared
# environment and DO NOT ship production secrets encrypted with it.
LOCAL_SECRET_ENCRYPTION_KEY=change-me-local-only

# --- Vision rate limiting ---
# Maximum vision categorization calls per user per household per UTC day.
# Protects against runaway LLM spend if a household member's account is
# compromised or misbehaves. Defaults to 50 when unset.
# VISION_DAILY_PER_USER_LIMIT=50
